# Redis Cache Configuration
# Add these environment variables to your .env file

# Redis Server Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=walangpass
REDIS_DB=0
NODE_ENV=production

# If Redis is running in Docker:
# REDIS_HOST=redis-dev  # Docker container name or localhost if exposed
# REDIS_PORT=6379
# REDIS_PASSWORD=walangpass  # Must match Docker Redis password

# To start Redis in Docker (if not already running):
# docker run --name redis-dev -d -p 6379:6379 redis:7-alpine redis-server --requirepass walangpass

# Verify Redis connection:
# docker exec redis-dev redis-cli -a walangpass ping
# Should output: PONG
