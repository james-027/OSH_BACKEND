# Environment Configuration Template
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_DATABASE=rest_api

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

PORT=3000
NODE_ENV=development

CORS_ORIGIN=*

BCRYPT_SALT_ROUNDS=10

# Security: Helmet HTTP Security Headers (default: true)
# Set to "false" to disable Helmet temporarily for debugging in production
USE_HELMET=true

# Redis Configuration (default: true)
# Set to "false" to disable Redis caching
USE_REDIS=true

# Upload Debugging (default: false)
# Set to "true" to enable detailed file-level processing logs [FILE QUEUED], [FILE PROCESSING START/COMPLETE]
# When disabled (default), logs are cleaner with progress checkpoints every 5 files
UPLOAD_DEBUG=false
